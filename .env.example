APP_NAME=Laravel
# Logo variant shown in the header and auth pages: A|B
APP_LOGO=A
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Legal page content placeholders: [DATE], [WEBSITE NAME], [CONTACT EMAIL], [WEBSITE URL]
LEGAL_DATE=2026-01-01
LEGAL_COUNTRY=United Kingdom
CONTACT_EMAIL=support@example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_THEME=default

# When false, all /admin routes return 404.
ADMIN_ENABLED=false

# Feature flags (boolean: true/false, 1/0). Keys are defined in config/features.php.
FEATURE_EXAMPLE_WIDGET=false
FEATURE_PLAYER_STATS_CSV_DOWNLOAD=false
FEATURE_SUBSCRIPTION_STRIPE_PAYMENTS=false
FEATURE_SIMPLE_CRYPTO_PAYMENT=false
FEATURE_PAY_WITH_METAMASK=false
FEATURE_LOGIN_GOOGLE=false
FEATURE_LOGIN_FACEBOOK=false
FEATURE_LOGIN_GITHUB=false
FEATURE_COOKIE_CONSENT=false
FEATURE_PROFILE_PHOTO=false

# Cookie consent banner (requires FEATURE_COOKIE_CONSENT=true).
# COOKIE_CONSENT_VERSION=1
# COOKIE_CONSENT_COOKIE_NAME=cookie_consent
# COOKIE_CONSENT_LIFETIME_DAYS=365
# GOOGLE_ANALYTICS_ID=

# Honeypot anti-bot fields on login, register, and forgot-password forms.
HONEYPOT_ENABLED=true
# HONEYPOT_FIELD_NAME=company_website
# HONEYPOT_TIMESTAMP_FIELD=form_started_at
# HONEYPOT_MIN_SECONDS=2
# HONEYPOT_MAX_SECONDS=3600

# MetaMask subscription payments (requires FEATURE_PAY_WITH_METAMASK=true).
METAMASK_TRANSACTION_WATCHER=http://localhost:3011/metamask/transaction
PAY_WITH_METAMASK_ETHEREUM_WALLET=
PAY_WITH_METAMASK_USDT_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D832831
PAY_WITH_METAMASK_USDC_CONTRACT=0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48
PAY_WITH_METAMASK_CHAIN_ID=1
# Optional ETH amounts per plan (wei). Omit to hide ETH. Configure at least USDT and/or USDC.
# PAY_WITH_METAMASK_ONE_DAY_ETH_WEI=
# PAY_WITH_METAMASK_ONE_MONTH_ETH_WEI=

# Simple crypto payments (USDT). Requires FEATURE_SIMPLE_CRYPTO_PAYMENT=true.
SIMPLE_CRYPTO_ETHEREUM_USDT_VISIBLE=false
SIMPLE_CRYPTO_ETHEREUM_USDT_ADDRESS=
SIMPLE_CRYPTO_TRON_USDT_VISIBLE=false
SIMPLE_CRYPTO_TRON_USDT_ADDRESS=

# Crypto watcher (POST when user clicks "I have paid"). Requires a queue worker (see QUEUE_CONNECTION).
CRYPTO_WATCHER=

# Telegram notifications (crypto "I have paid" + Stripe subscription fulfilled). Requires a queue worker (see QUEUE_CONNECTION).
TELEGRAM_API_KEY=
TELEGRAM_CHAT_ID=
# TELEGRAM_QUEUE_CONNECTION=redis
# TELEGRAM_QUEUE=default

# Telegram promobot (POST /api/telegram/start). X-Telegram-Bot-Api-Secret-Token must match TELEGRAM_PROMOBOT_API_SECRET.
TELEGRAM_PROMOBOT_API_SECRET=
# TELEGRAM_PROMOBOT_DAYS=3

# Stripe (card payments on /subscribe/payment/{plan}; requires FEATURE_SUBSCRIPTION_STRIPE_PAYMENTS=true)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Subscription plans (visibility + price). Visible plans are always subscribable.
SUBSCRIPTION_TERMS_VERSION=1

SUBSCRIPTION_CURRENCY=EUR
SUBSCRIPTION_ONE_DAY_VISIBLE=true
SUBSCRIPTION_ONE_DAY_PRICE=2.99
SUBSCRIPTION_ONE_WEEK_VISIBLE=true
SUBSCRIPTION_ONE_WEEK_PRICE=9.99
SUBSCRIPTION_ONE_MONTH_VISIBLE=true
SUBSCRIPTION_ONE_MONTH_PRICE=29.99
SUBSCRIPTION_THREE_MONTHS_VISIBLE=true
SUBSCRIPTION_THREE_MONTHS_PRICE=79.99
SUBSCRIPTION_ONE_YEAR_VISIBLE=true
SUBSCRIPTION_ONE_YEAR_PRICE=249.99

# Promocodes (prefix for codes generated by promocodes:generate)
PROMOCODE_PREFIX=PROMO-

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Sessions in Redis (separate DB from cache — see REDIS_SESSION_DB / REDIS_CACHE_DB).
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Auth emails (verification + password reset) and other queued notifications require a worker:
# php artisan queue:work
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Public pages: caches <main> HTML in Redis (header/subbar/footer stay fresh).
PAGES_CACHE_ENABLED=true
PAGES_CACHE_TTL=300
PAGES_CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

# phpredis = PECL extension (faster). predis = pure PHP (no extension required).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Resend (set MAIL_MAILER=resend and RESEND_API_KEY when using Resend)
# RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

VITE_APP_NAME="${APP_NAME}"
