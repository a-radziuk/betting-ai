# Copy to .env and fill in values. TELEGRAM_PROMOBOT_API_SECRET must match the Laravel app (sent as X-Telegram-Bot-Api-Secret-Token).
# TELEGRAM_BOT_TOKEN must match TELEGRAM_PROMOBOT_TOKEN on the Laravel app.
TELEGRAM_BOT_TOKEN=
PLATFORM_APP_URL=https://your-app.example
TELEGRAM_PROMOBOT_API_SECRET=
